# ── DataCleanEnv — Environment Variables ─────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit the .env file — it is listed in .gitignore.

# Required for AI-powered cleaning recommendations (batch_cleaner/ai_module)
OPENAI_API_KEY=sk-...your-openai-key-here...

# Required if you use Hugging Face models
HUGGING_FACE_HUB_TOKEN=hf_...your-token-here...
